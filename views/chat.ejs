<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0">
    <title>Chat — <%= otherUser ? otherUser.name : 'User' %></title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <style>
        *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

        html, body {
            height: 100%;
            font-family: 'Segoe UI', -apple-system, BlinkMacSystemFont, sans-serif;
            background: #eae6df;
            overflow: hidden; /* prevent body scroll — only messages-area scrolls */
        }

        /* ─────────── Page shell: fixed full-height flex column ─────────── */
        #chat-shell {
            display: flex;
            flex-direction: column;
            height: 100vh;
            max-width: 780px;
            margin: 0 auto;
            background: #eae6df;
            box-shadow: 0 0 20px rgba(0,0,0,0.12);
        }

        /* ─────────── Header ─────────── */
        #chat-header {
            flex-shrink: 0;
            display: flex;
            align-items: center;
            gap: 10px;
            background: #075e54;
            color: #fff;
            padding: 10px 14px;
            min-height: 58px;
        }
        #chat-header .back-btn {
            color: rgba(255,255,255,0.9);
            text-decoration: none;
            font-size: 1.1rem;
            padding: 4px 6px;
            border-radius: 50%;
            line-height: 1;
            flex-shrink: 0;
        }
        #chat-header .back-btn:hover { background: rgba(255,255,255,0.12); }

        .hdr-avatar {
            width: 40px; height: 40px;
            border-radius: 50%;
            background: #128C7E;
            border: 2px solid rgba(255,255,255,0.3);
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem; color: #fff;
            flex-shrink: 0;
            overflow: hidden;
        }
        .hdr-avatar img { width: 100%; height: 100%; object-fit: cover; }

        .hdr-info { flex: 1; min-width: 0; }
        .hdr-info .name {
            font-size: 0.98rem;
            font-weight: 600;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }
        .hdr-info .sub {
            font-size: 0.72rem;
            opacity: 0.82;
            margin-top: 1px;
        }
        .status-dot {
            display: inline-block;
            width: 7px; height: 7px;
            border-radius: 50%;
            margin-right: 4px;
            vertical-align: middle;
        }
        .dot-active  { background: #4ade80; }
        .dot-locked  { background: #f87171; }
        .dot-pending { background: #facc15; }

        /* ─────────── Order info strip ─────────── */
        #order-strip {
            flex-shrink: 0;
            background: #dcf8c6;
            border-bottom: 1px solid #c5e8b0;
            padding: 6px 14px;
            font-size: 0.78rem;
            color: #2d4a22;
            display: flex;
            align-items: center;
            gap: 6px;
            flex-wrap: wrap;
        }
        #order-strip .badge-status {
            display: inline-block;
            padding: 2px 8px;
            border-radius: 10px;
            font-size: 0.7rem;
            font-weight: 600;
            margin-left: auto;
        }
        .bs-pending    { background: #fef3c7; color: #92400e; }
        .bs-inprogress { background: #dbeafe; color: #1e40af; }
        .bs-completed  { background: #d1fae5; color: #065f46; }
        .bs-cancelled  { background: #f3f4f6; color: #6b7280; }

        /* ─────────── Messages area — THIS IS THE ONLY SCROLLABLE PART ─────────── */
        #messages-area {
            flex: 1;
            overflow-y: auto;
            overflow-x: hidden;
            padding: 12px 14px 8px;
            display: flex;
            flex-direction: column;
            gap: 2px;
            background: #eae6df;
            /* whatsapp subtle pattern */
            background-image: url("data:image/svg+xml,%3Csvg width='60' height='60' viewBox='0 0 60 60' xmlns='http://www.w3.org/2000/svg'%3E%3Cg fill='none' fill-rule='evenodd'%3E%3Cg fill='%23c9bfb5' fill-opacity='0.15'%3E%3Cpath d='M36 34v-4h-2v4h-4v2h4v4h2v-4h4v-2h-4zm0-30V0h-2v4h-4v2h4v4h2V6h4V4h-4zM6 34v-4H4v4H0v2h4v4h2v-4h4v-2H6zM6 4V0H4v4H0v2h4v4h2V6h4V4H6z'/%3E%3C/g%3E%3C/g%3E%3C/svg%3E");
        }
        /* custom scrollbar */
        #messages-area::-webkit-scrollbar { width: 5px; }
        #messages-area::-webkit-scrollbar-track { background: transparent; }
        #messages-area::-webkit-scrollbar-thumb { background: #b0a99c; border-radius: 3px; }

        /* ─────────── Empty state ─────────── */
        .empty-chat {
            flex: 1;
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            color: #9e9e9e;
            padding: 30px;
            text-align: center;
        }
        .empty-chat i { font-size: 2.8rem; margin-bottom: 10px; color: #bbb; }
        .empty-chat p { font-size: 0.9rem; }

        /* ─────────── Day separator ─────────── */
        .day-sep {
            text-align: center;
            margin: 10px 0 8px;
            position: relative;
        }
        .day-sep span {
            background: #d9cfca;
            color: #666;
            font-size: 0.7rem;
            padding: 3px 10px;
            border-radius: 6px;
            display: inline-block;
        }

        /* ─────────── Message rows ─────────── */
        .msg-row {
            display: flex;
            align-items: flex-end;
            gap: 6px;
            max-width: 100%;
            margin-bottom: 2px;
        }
        .msg-row.mine  { flex-direction: row-reverse; }

        /* small avatar beside each message */
        .msg-av {
            width: 26px; height: 26px;
            border-radius: 50%;
            background: #128C7E;
            display: flex; align-items: center; justify-content: center;
            font-size: 0.65rem; color: #fff;
            flex-shrink: 0;
            overflow: hidden;
            align-self: flex-end;
            margin-bottom: 2px;
        }
        .msg-av img { width: 100%; height: 100%; object-fit: cover; }
        .msg-row.mine .msg-av { background: #075e54; }

        /* bubble */
        .msg-bubble {
            max-width: min(120%, 420px);
            padding: 7px 11px 5px;
            font-size: 0.875rem;
            line-height: 1.45;
            word-break: break-word;
            position: relative;
            border-radius: 8px;
        }
        /* tail on first bubble in group */
        .msg-row.theirs .msg-bubble {
            background: #ffffff;
            color: #111;
            border-top-left-radius: 2px;
            box-shadow: 0 1px 1px rgba(0,0,0,0.1);
        }
        .msg-row.mine .msg-bubble {
            background: #dcf8c6;
            color: #111;
            border-top-right-radius: 2px;
            box-shadow: 0 1px 1px rgba(0,0,0,0.1);
        }
        .msg-meta {
            display: flex;
            align-items: center;
            justify-content: flex-end;
            gap: 4px;
            margin-top: 3px;
        }
        .msg-time {
            font-size: 0.64rem;
            color: #8e9298;
            white-space: nowrap;
        }
        .msg-row.mine .msg-time { color: #6a9868; }

        /* sender name above bubble (only for "theirs") */
        .sender-label {
            font-size: 0.7rem;
            font-weight: 600;
            color: #128C7E;
            margin-bottom: 2px;
            padding-left: 2px;
        }

        /* ─────────── Locked / pending notice in messages area ─────────── */
        .chat-notice {
            text-align: center;
            padding: 8px 16px;
            margin: 6px auto;
            background: rgba(255,255,255,0.72);
            border-radius: 8px;
            font-size: 0.75rem;
            color: #555;
            max-width: 320px;
        }

        /* ─────────── Input bar — always fixed at bottom ─────────── */
        #input-bar {
            flex-shrink: 0;
            display: flex;
            align-items: flex-end;
            gap: 8px;
            padding: 8px 10px;
            background: #f0f2f5;
            border-top: 1px solid #ddd;
        }
        #msg-input {
            flex: 1;
            border: none;
            border-radius: 22px;
            padding: 9px 16px;
            font-size: 0.9rem;
            resize: none;
            outline: none;
            background: #fff;
            box-shadow: 0 1px 2px rgba(0,0,0,0.08);
            line-height: 1.4;
            max-height: 120px;
            overflow-y: auto;
            font-family: inherit;
            display: block;
        }
        #send-btn {
            width: 46px; height: 46px;
            border-radius: 50%;
            background: #075e54;
            color: #fff;
            border: none;
            display: flex; align-items: center; justify-content: center;
            font-size: 1rem;
            cursor: pointer;
            flex-shrink: 0;
            transition: background 0.15s, transform 0.1s;
            box-shadow: 0 1px 4px rgba(0,0,0,0.2);
        }
        #send-btn:hover  { background: #128C7E; }
        #send-btn:active { transform: scale(0.92); }
        #send-btn:disabled { background: #b0b0b0; cursor: not-allowed; transform: none; }

        /* ─────────── Locked input bar ─────────── */
        #locked-bar {
            flex-shrink: 0;
            text-align: center;
            padding: 12px 16px;
            background: #f8f9fa;
            border-top: 1px solid #e0e0e0;
            font-size: 0.82rem;
            color: #777;
        }
        #locked-bar i { margin-right: 5px; color: #999; }
    </style>
</head>
<body>

<div id="chat-shell">

    <!-- ── Header ── -->
    <div id="chat-header">
        <a class="back-btn" href="<%= backUrl %>">
            <i class="fas fa-arrow-left"></i>
        </a>
        <div class="hdr-avatar">
            <% if (otherUser && otherUser.profileImage) { %>
                <img src="<%= otherUser.profileImage %>" alt="">
            <% } else { %>
                <i class="fas fa-user"></i>
            <% } %>
        </div>
        <div class="hdr-info">
            <div class="name"><%= otherUser ? otherUser.name : 'User' %></div>
            <div class="sub">
                <% if (order.status === 'in-progress') { %>
                    <span class="status-dot dot-active"></span>Job in progress
                <% } else if (order.status === 'completed') { %>
                    <span class="status-dot dot-locked"></span>Job completed
                <% } else if (order.status === 'pending') { %>
                    <span class="status-dot dot-pending"></span>Awaiting acceptance
                <% } else { %>
                    <span class="status-dot dot-locked"></span>Cancelled
                <% } %>
            </div>
        </div>
    </div>

    <!-- ── Order strip ── -->
    <div id="order-strip">
        <i class="fas fa-wrench"></i>
        <strong><%= order.service %></strong>
        <% if (order.amount) { %>· <i class="fas fa-rupee-sign" style="font-size:0.72rem"></i>₹<%= order.amount %><% } %>
        <% if (order.description) { %>
            · <%= order.description.length > 55 ? order.description.substring(0,55) + '…' : order.description %>
        <% } %>
        <span class="badge-status
            <% if(order.status==='pending')        { %>bs-pending
            <% } else if(order.status==='in-progress') { %>bs-inprogress
            <% } else if(order.status==='completed')   { %>bs-completed
            <% } else                              { %>bs-cancelled<% } %>">
            <%= order.status === 'in-progress' ? 'In Progress' : order.status.charAt(0).toUpperCase() + order.status.slice(1) %>
        </span>
    </div>

    <!-- ── Messages area ── -->
    <div id="messages-area">

        <% if (messages.length === 0) { %>
            <div class="empty-chat">
                <i class="fas fa-comments"></i>
                <p>No messages yet.<% if (order.status === 'in-progress') { %><br>Say hello!<% } %></p>
            </div>
        <% } %>

        <% let lastDay = ''; %>
        <% messages.forEach(function(msg) { %>
            <% const d = new Date(msg.createdAt); %>
            <% const dayLabel = d.toLocaleDateString('en-IN', { day:'numeric', month:'short', year:'numeric' }); %>
            <% if (dayLabel !== lastDay) { lastDay = dayLabel; %>
                <div class="day-sep"><span><%= dayLabel %></span></div>
            <% } %>

            <% const isMe = msg.senderId._id.toString() === currentUserId; %>
            <div class="msg-row <%= isMe ? 'mine' : 'theirs' %>">
                <div class="msg-av">
                    <% if (msg.senderId.profileImage) { %>
                        <img src="<%= msg.senderId.profileImage %>" alt="">
                    <% } else { %>
                        <i class="fas fa-user" style="font-size:0.6rem"></i>
                    <% } %>
                </div>
                <div style="display:flex;flex-direction:column;align-items:<%= isMe ? 'flex-end' : 'flex-start' %>">
                    <% if (!isMe) { %>
                        <div class="sender-label"><%= msg.senderId.name %></div>
                    <% } %>
                    <div class="msg-bubble">
                        <%= msg.text %>
                        <div class="msg-meta">
                            <span class="msg-time">
                                <%= d.toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' }) %>
                            </span>
                            <% if (isMe) { %><i class="fas fa-check-double" style="font-size:0.6rem;color:#6a9868;"></i><% } %>
                        </div>
                    </div>
                </div>
            </div>
        <% }); %>

        <!-- spacer so last message isn't hidden behind input bar -->
        <div style="height:4px;flex-shrink:0;"></div>
    </div>

    <!-- ── Input bar or Locked bar ── -->
    <% if (order.status === 'in-progress') { %>
    <div id="input-bar">
        <textarea id="msg-input" placeholder="Type a message…" rows="1"></textarea>
        <button id="send-btn" title="Send">
            <i class="fas fa-paper-plane"></i>
        </button>
    </div>
    <% } else { %>
    <div id="locked-bar">
        <% if (order.status === 'completed') { %>
            <i class="fas fa-lock"></i>This job is completed — messaging is disabled
        <% } else if (order.status === 'pending') { %>
            <i class="fas fa-hourglass-half"></i>Messaging opens after the worker accepts
        <% } else { %>
            <i class="fas fa-ban"></i>This job was cancelled — messaging is disabled
        <% } %>
    </div>
    <% } %>

</div><!-- end #chat-shell -->

<script>
    const orderId       = '<%= order._id %>';
    const currentUserId = '<%= currentUserId %>';
    const isActive      = <%= order.status === 'in-progress' ? 'true' : 'false' %>;

    const area    = document.getElementById('messages-area');
    const input   = document.getElementById('msg-input');
    const sendBtn = document.getElementById('send-btn');

    function scrollBottom(smooth) {
        area.scrollTo({ top: area.scrollHeight, behavior: smooth ? 'smooth' : 'instant' });
    }
    scrollBottom(false);

    if (isActive && input && sendBtn) {

        input.addEventListener('input', function () {
            this.style.height = 'auto';
            this.style.height = Math.min(this.scrollHeight, 120) + 'px';
        });

        input.addEventListener('keydown', function (e) {
            if (e.key === 'Enter' && !e.shiftKey) {
                e.preventDefault();
                sendMessage();
            }
        });
        sendBtn.addEventListener('click', sendMessage);

        async function sendMessage() {
            const text = input.value.trim();
            if (!text) return;
            sendBtn.disabled = true;
            input.disabled   = true;
            try {
                const res  = await fetch('/chat/' + orderId + '/send', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ text })
                });
                const data = await res.json();
                if (data.success) {
                    input.value        = '';
                    input.style.height = 'auto';
                    appendMessage(data.message, true);
                    scrollBottom(true);
                } else {
                    showToast(data.message || 'Failed to send.', 'error');
                }
            } catch (e) {
                showToast('Network error — please try again.', 'error');
            }
            sendBtn.disabled = false;
            input.disabled   = false;
            input.focus();
        }

        let lastMsgTime = '<%= messages.length > 0 ? messages[messages.length-1].createdAt.toISOString() : new Date(0).toISOString() %>';

        setInterval(async () => {
            try {
                const res  = await fetch('/chat/' + orderId + '/poll?since=' + encodeURIComponent(lastMsgTime));
                const data = await res.json();
                if (data.messages && data.messages.length > 0) {
                    const wasAtBottom = area.scrollHeight - area.scrollTop - area.clientHeight < 60;
                    data.messages.forEach(msg => {
                        if (msg.senderId !== currentUserId) appendMessage(msg, false);
                    });
                    lastMsgTime = data.messages[data.messages.length - 1].createdAt;
                    if (wasAtBottom) scrollBottom(true);
                }
                if (data.orderStatus && data.orderStatus !== 'in-progress') location.reload();
            } catch (e) {}
        }, 4000);
    }

    function appendMessage(msg, isMe) {
        const empty = area.querySelector('.empty-chat');
        if (empty) empty.remove();
        const row = document.createElement('div');
        row.className = 'msg-row ' + (isMe ? 'mine' : 'theirs');
        const timeStr = new Date(msg.createdAt).toLocaleTimeString('en-IN', { hour:'2-digit', minute:'2-digit' });
        row.innerHTML =
            '<div class="msg-av"><i class="fas fa-user" style="font-size:0.6rem"></i></div>' +
            '<div style="display:flex;flex-direction:column;align-items:' + (isMe ? 'flex-end' : 'flex-start') + '">' +
                '<div class="msg-bubble">' +
                    escHtml(msg.text) +
                    '<div class="msg-meta">' +
                        '<span class="msg-time">' + timeStr + '</span>' +
                        (isMe ? '<i class="fas fa-check-double" style="font-size:0.6rem;color:#6a9868;"></i>' : '') +
                    '</div>' +
                '</div>' +
            '</div>';
        area.appendChild(row);
    }

    function escHtml(s) {
        return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    function showToast(msg, type) {
        const t = document.createElement('div');
        t.style.cssText = 'position:fixed;bottom:80px;left:50%;transform:translateX(-50%);' +
            'background:' + (type === 'error' ? '#c0392b' : '#2e7d32') + ';color:#fff;' +
            'padding:8px 18px;border-radius:20px;font-size:0.82rem;z-index:999;box-shadow:0 2px 8px rgba(0,0,0,0.2)';
        t.textContent = msg;
        document.body.appendChild(t);
        setTimeout(() => t.remove(), 3000);
    }
</script>
</html>
