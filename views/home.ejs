    <!-- Service card click handlers -->
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const serviceCards = document.querySelectorAll('.service-card');
            
            serviceCards.forEach(card => {
                card.addEventListener('click', function() {
                    const profession = this.getAttribute('data-profession');
                    window.location.href = `/find-labour?profession=${encodeURIComponent(profession)}`;
                });
                
                card.addEventListener('mouseenter', function() {
                    this.style.cursor = 'pointer';
                    this.style.transform = 'translateY(-5px)';
                });
                
                card.addEventListener('mouseleave', function() {
                    this.style.transform = 'translateY(0)';
                });

                card.addEventListener('mousedown', function() {
                    this.style.transform = 'translateY(-2px) scale(0.98)';
                });
                
                card.addEventListener('mouseup', function() {
                    this.style.transform = 'translateY(-5px)';
                });
            });

            // Smooth scrolling
            document.querySelectorAll('a[href^="#"]').forEach(anchor => {
                anchor.addEventListener('click', function (e) {
                    e.preventDefault();
                    const target = document.querySelector(this.getAttribute('href'));
                    if (target) {
                        target.scrollIntoView({ behavior: 'smooth', block: 'start' });
                    }
                });
            });

            // Apply to a public job post
            let activeHomeApplyBtn = null;
            const homeApplyModalEl = document.getElementById('homeApplyModal');
            const homeApplyModal = homeApplyModalEl ? new bootstrap.Modal(homeApplyModalEl) : null;

            document.querySelectorAll('.job-apply-btn').forEach(btn => {
                btn.addEventListener('click', function() {
                    if (!homeApplyModal) return;
                    activeHomeApplyBtn = this;
                    document.getElementById('homeApplyJobTitle').textContent = this.dataset.jobTitle || '';
                    document.getElementById('homeApplyMessage').value = '';
                    homeApplyModal.show();
                });
            });

            const confirmHomeApplyBtn = document.getElementById('confirmHomeApplyBtn');
            if (confirmHomeApplyBtn) {
                confirmHomeApplyBtn.addEventListener('click', async function() {
                    if (!activeHomeApplyBtn) return;
                    const jobId = activeHomeApplyBtn.dataset.jobId;
                    const message = document.getElementById('homeApplyMessage').value.trim();

                    this.disabled = true;
                    this.textContent = 'Sending...';

                    try {
                        const res = await fetch(`/jobs/${jobId}/respond`, {
                            method: 'POST',
                            headers: { 'Content-Type': 'application/json' },
                            body: JSON.stringify({ message })
                        });
                        const data = await res.json();

                        if (data.success) {
                            activeHomeApplyBtn.textContent = 'Applied';
                            activeHomeApplyBtn.disabled = true;
                            activeHomeApplyBtn.classList.remove('btn-success');
                            activeHomeApplyBtn.classList.add('btn-secondary');
                            homeApplyModal.hide();
                        } else {
                            alert(data.message || 'Could not apply to this job');
                        }
                    } catch (err) {
                        console.error('Error applying to job:', err);
                        alert('Error applying to job. Please try again.');
                    } finally {
                        this.disabled = false;
                        this.textContent = 'Send Application';
                    }
                });
            }
        });
    </script>

