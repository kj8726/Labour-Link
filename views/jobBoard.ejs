<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Browse Jobs - LabourLink</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
</head>
<body class="bg-light">
    <header class="bg-dark text-white py-3 mb-4">
        <div class="container d-flex justify-content-between align-items-center">
            <div class="d-flex align-items-center">
                <a href="/" class="text-white me-3">
                    <i class="fas fa-arrow-left"></i>
                </a>
                <h1 class="h4 mb-0"><i class="fas fa-briefcase me-2"></i>Browse Jobs</h1>
            </div>
            <% if (user) { %>
                <a href="<%= user.userType === 'labour' ? '/profile/labour' : '/profile/customer' %>" class="btn btn-outline-light btn-sm">
                    <i class="fas fa-user me-1"></i>My Profile
                </a>
            <% } else { %>
                <a href="/login" class="btn btn-outline-light btn-sm">Login</a>
            <% } %>
        </div>
    </header>

    <div class="container pb-5">
        <form method="GET" action="/jobs" class="mb-4">
            <div class="row g-2 align-items-end justify-content-center">
                <div class="col-auto">
                    <label for="profession" class="form-label mb-1">Filter by Profession</label>
                    <select class="form-select" id="profession" name="profession" onchange="this.form.submit()">
                        <option value="all" <%= selectedProfession === 'all' ? 'selected' : '' %>>All Professions</option>
                        <% professions.forEach(function(p) { %>
                            <option value="<%= p %>" <%= selectedProfession === p ? 'selected' : '' %>><%= p %></option>
                        <% }); %>
                    </select>
                </div>
            </div>
            <p class="text-center text-muted small mt-2 mb-0">
                "All Professions" also includes general requests open to every trade.
            </p>
        </form>

        <div class="row">
            <% if (jobPosts.length > 0) { %>
                <% jobPosts.forEach(function(job) { %>
                    <div class="col-lg-6 mb-3">
                        <div class="card shadow-sm h-100">
                            <div class="card-body">
                                <div class="d-flex justify-content-between align-items-start mb-2">
                                    <h5 class="card-title mb-0"><%= job.title %></h5>
                                    <span class="badge <%= job.profession ? 'bg-success' : 'bg-info' %>">
                                        <%= job.profession || 'Any Profession' %>
                                    </span>
                                </div>
                                <p class="card-text text-muted"><%= job.description %></p>
                                <ul class="list-unstyled small text-muted mb-3">
                                    <li><i class="fas fa-user me-1"></i> <%= job.customerId.name %></li>
                                    <% if (job.address && job.address.city) { %>
                                        <li><i class="fas fa-map-marker-alt me-1"></i> <%= job.address.city %></li>
                                    <% } %>
                                    <% if (job.budget) { %>
                                        <li><i class="fas fa-rupee-sign me-1"></i> ₹<%= job.budget %></li>
                                    <% } %>
                                    <% if (job.workersNeeded > 1) { %>
                                        <li><i class="fas fa-users me-1"></i> <%= job.workersNeeded %> workers needed</li>
                                    <% } %>
                                    <li><i class="fas fa-calendar me-1"></i> Posted <%= new Date(job.createdAt).toLocaleDateString() %></li>
                                </ul>
                                <div class="d-flex gap-2">
                                    <% if (user && user.userType === 'labour') { %>
                                        <button class="btn btn-success btn-sm flex-fill job-apply-btn" data-job-id="<%= job._id %>" data-job-title="<%= job.title %>">
                                            Apply Now
                                        </button>
                                    <% } else if (!user) { %>
                                        <a href="/login" class="btn btn-success btn-sm flex-fill">Login to Apply</a>
                                    <% } %>
                                    <% if (user) { %>
                                        <button class="btn btn-outline-secondary btn-sm job-report-btn" data-job-id="<%= job._id %>" title="Report this job post">
                                            <i class="fas fa-flag"></i>
                                        </button>
                                    <% } %>
                                </div>
                            </div>
                        </div>
                    </div>
                <% }); %>
            <% } else { %>
                <div class="col-12 text-center py-5">
                    <i class="fas fa-briefcase fa-3x text-muted mb-3"></i>
                    <h5>No open jobs found</h5>
                    <p class="text-muted">Try a different profession filter, or check back later.</p>
                </div>
            <% } %>
        </div>
    </div>

    <!-- Apply Modal -->
    <div class="modal fade" id="applyModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Apply to "<span id="applyJobTitle"></span>"</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label for="applyMessage" class="form-label">Message to the customer (optional)</label>
                    <textarea class="form-control" id="applyMessage" rows="3" maxlength="500"
                              placeholder="e.g. I'm available today, my rate is ₹400"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-success" id="confirmApplyBtn">Send Application</button>
                </div>
            </div>
        </div>
    </div>

    <!-- Report Modal -->
    <div class="modal fade" id="reportModal" tabindex="-1">
        <div class="modal-dialog">
            <div class="modal-content">
                <div class="modal-header">
                    <h5 class="modal-title">Report this job post</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <label for="reportReason" class="form-label">What's wrong with this post? (optional)</label>
                    <textarea class="form-control" id="reportReason" rows="3" maxlength="300"
                              placeholder="e.g. Spam, fake job, inappropriate content"></textarea>
                </div>
                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                    <button type="button" class="btn btn-danger" id="confirmReportBtn">Submit Report</button>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script>
        let activeApplyBtn = null;
        let activeReportBtn = null;
        const applyModal = new bootstrap.Modal(document.getElementById('applyModal'));
        const reportModal = new bootstrap.Modal(document.getElementById('reportModal'));

        document.querySelectorAll('.job-apply-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                activeApplyBtn = btn;
                document.getElementById('applyJobTitle').textContent = btn.dataset.jobTitle || '';
                document.getElementById('applyMessage').value = '';
                applyModal.show();
            });
        });

        document.getElementById('confirmApplyBtn').addEventListener('click', async function() {
            if (!activeApplyBtn) return;
            const jobId = activeApplyBtn.dataset.jobId;
            const message = document.getElementById('applyMessage').value.trim();

            this.disabled = true;
            this.textContent = 'Sending...';

            try {
                const res = await fetch(`/jobs/${jobId}/respond`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ message })
                });
                const data = await res.json();

                if (data.success) {
                    activeApplyBtn.textContent = 'Applied';
                    activeApplyBtn.disabled = true;
                    activeApplyBtn.classList.remove('btn-success');
                    activeApplyBtn.classList.add('btn-secondary');
                    applyModal.hide();
                } else {
                    alert(data.message || 'Could not apply to this job');
                }
            } catch (err) {
                console.error('Error applying to job:', err);
                alert('Error applying to job. Please try again.');
            } finally {
                this.disabled = false;
                this.textContent = 'Send Application';
            }
        });

        document.querySelectorAll('.job-report-btn').forEach(btn => {
            btn.addEventListener('click', function() {
                activeReportBtn = btn;
                document.getElementById('reportReason').value = '';
                reportModal.show();
            });
        });

        document.getElementById('confirmReportBtn').addEventListener('click', async function() {
            if (!activeReportBtn) return;
            const jobId = activeReportBtn.dataset.jobId;
            const reason = document.getElementById('reportReason').value.trim();

            this.disabled = true;
            this.textContent = 'Submitting...';

            try {
                const res = await fetch(`/jobs/${jobId}/report`, {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ reason })
                });
                const data = await res.json();

                alert(data.message || (data.success ? 'Reported.' : 'Could not report this job post'));
                if (data.success) {
                    activeReportBtn.disabled = true;
                    reportModal.hide();
                }
            } catch (err) {
                console.error('Error reporting job:', err);
                alert('Error reporting job. Please try again.');
            } finally {
                this.disabled = false;
                this.textContent = 'Submit Report';
            }
        });
    </script>
</body>
</html>
