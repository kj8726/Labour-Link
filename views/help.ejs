<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Help & Support - LabourLink</title>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <style>
        body { background: #f8f9fa; }
        .help-header {
            background: linear-gradient(135deg, #198754, #146c43);
            color: #fff;
            padding: 50px 0 40px;
        }
        .accordion-button:not(.collapsed) {
            background-color: #e8f5e9;
            color: #146c43;
        }
        .accordion-button:focus {
            box-shadow: none;
            border-color: rgba(0,0,0,.125);
        }
        .contact-card {
            border: none;
            border-radius: 12px;
        }
        .role-pill {
            font-size: 0.8rem;
        }
    </style>
</head>
<body>
    <header class="help-header text-center">
        <div class="container">
            <a href="<%= user ? (user.userType === 'labour' ? '/profile/labour' : '/profile/customer') : '/' %>" class="text-white text-decoration-none d-inline-block mb-3">
                <i class="fas fa-arrow-left me-2"></i>Back
            </a>
            <h1 class="h2 mb-2"><i class="fas fa-life-ring me-2"></i>Help & Support</h1>
            <p class="mb-0">
                <% if (user && user.userType === 'labour') { %>
                    Answers for professionals using LabourLink
                <% } else if (user && user.userType === 'customer') { %>
                    Answers for customers using LabourLink
                <% } else { %>
                    Find answers, or reach out to our team
                <% } %>
            </p>
        </div>
    </header>

    <div class="container py-5">
        <div class="row justify-content-center">
            <div class="col-lg-8">

                <% if (!user) { %>
                <!-- Logged-out: let them pick which set of FAQs to see -->
                <div class="text-center mb-5">
                    <p class="text-muted mb-3">I'm using LabourLink as a...</p>
                    <div class="btn-group" role="group">
                        <a href="#customer-faq" class="btn btn-outline-success">I'm a Customer</a>
                        <a href="#worker-faq" class="btn btn-outline-success">I'm a Professional</a>
                    </div>
                </div>
                <% } %>

                <!-- ===================== CUSTOMER FAQ ===================== -->
                <% if (!user || user.userType === 'customer') { %>
                <div id="customer-faq" class="mb-5">
                    <h4 class="mb-3"><i class="fas fa-user me-2 text-success"></i>For Customers</h4>
                    <div class="accordion" id="customerAccordion">

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c1">
                                    How do I request a professional for a job?
                                </button>
                            </h2>
                            <div id="c1" class="accordion-collapse collapse" data-bs-parent="#customerAccordion">
                                <div class="accordion-body">
                                    Go to <strong>Find Professionals</strong>, browse or search by trade, and open a
                                    professional's profile to send them a direct request. They'll accept or decline
                                    it from their end.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c2">
                                    What's the difference between a direct request and a public job post?
                                </button>
                            </h2>
                            <div id="c2" class="accordion-collapse collapse" data-bs-parent="#customerAccordion">
                                <div class="accordion-body">
                                    A <strong>direct request</strong> goes to one professional you've already chosen.
                                    A <strong>public job post</strong> (Profile &rarr; Post a Public Job) is visible
                                    to every matching professional — or to everyone, if you're not sure which trade
                                    you need. Interested professionals respond, and you pick who to hire.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c3">
                                    I'm not sure what kind of professional I need. What do I do?
                                </button>
                            </h2>
                            <div id="c3" class="accordion-collapse collapse" data-bs-parent="#customerAccordion">
                                <div class="accordion-body">
                                    Post a public job and leave "Profession Needed" set to
                                    <strong>"Not sure / Any Profession"</strong>. It'll be shown to professionals
                                    across every trade, and you can review who responds before hiring anyone.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c4">
                                    How do I leave a review?
                                </button>
                            </h2>
                            <div id="c4" class="accordion-collapse collapse" data-bs-parent="#customerAccordion">
                                <div class="accordion-body">
                                    Once a professional marks your order as <strong>completed</strong>, a "Leave a
                                    Review" option appears on that order in your Order History. Reviews can only be
                                    left on completed orders.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c5">
                                    Can I cancel or edit a public job post?
                                </button>
                            </h2>
                            <div id="c5" class="accordion-collapse collapse" data-bs-parent="#customerAccordion">
                                <div class="accordion-body">
                                    Yes — from "My Public Job Posts" on your profile, you can <strong>Edit</strong> or
                                    <strong>Cancel</strong> any post that's still open. Once you've hired someone (or
                                    it's expired), it can no longer be edited.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#c6">
                                    A professional hasn't responded or showed up. What should I do?
                                </button>
                            </h2>
                            <div id="c6" class="accordion-collapse collapse" data-bs-parent="#customerAccordion">
                                <div class="accordion-body">
                                    Try reaching out via the contact details on their profile first. If that doesn't
                                    work, email us at <a href="mailto:support@labourlink.com">support@labourlink.com</a>
                                    with the order details and we'll help sort it out.
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <% } %>

                <!-- ===================== WORKER FAQ ===================== -->
                <% if (!user || user.userType === 'labour') { %>
                <div id="worker-faq" class="mb-5">
                    <h4 class="mb-3"><i class="fas fa-tools me-2 text-success"></i>For Professionals</h4>
                    <div class="accordion" id="workerAccordion">

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#w1">
                                    How do I get more job requests?
                                </button>
                            </h2>
                            <div id="w1" class="accordion-collapse collapse" data-bs-parent="#workerAccordion">
                                <div class="accordion-body">
                                    Complete your profile fully — a profile photo, accurate profession, experience,
                                    and wage rate all help customers trust and choose you. A complete profile is also
                                    required before you can apply to public job posts.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#w2">
                                    What's the public Job Board, and how do I apply?
                                </button>
                            </h2>
                            <div id="w2" class="accordion-collapse collapse" data-bs-parent="#workerAccordion">
                                <div class="accordion-body">
                                    The Job Board (<strong>Browse Jobs</strong>, also shown on the home page) lists
                                    public requests from customers — both jobs matching your trade and general
                                    requests open to everyone. Click <strong>Apply Now</strong> and optionally add a
                                    short message with your availability or rate.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#w3">
                                    How do I know if a customer accepted my application?
                                </button>
                            </h2>
                            <div id="w3" class="accordion-collapse collapse" data-bs-parent="#workerAccordion">
                                <div class="accordion-body">
                                    You'll get a notification (bell icon, top right) when a customer accepts or
                                    declines your response. Once accepted, it becomes a regular request in your
                                    Profile, which you can accept and manage from there.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#w4">
                                    How do reviews and ratings work?
                                </button>
                            </h2>
                            <div id="w4" class="accordion-collapse collapse" data-bs-parent="#workerAccordion">
                                <div class="accordion-body">
                                    After you mark a job as completed, the customer can leave a star rating and
                                    written review. These show up on your public profile and contribute to your
                                    overall rating — there's no way to remove a fair review, so it's worth
                                    confirming work is fully done before marking it complete.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#w5">
                                    How do I update my profession, rate, or photo?
                                </button>
                            </h2>
                            <div id="w5" class="accordion-collapse collapse" data-bs-parent="#workerAccordion">
                                <div class="accordion-body">
                                    Go to your Profile and use <strong>Edit Profile</strong> to update your
                                    profession, hourly/daily rate, experience, and profile photo at any time.
                                </div>
                            </div>
                        </div>

                        <div class="accordion-item">
                            <h2 class="accordion-header">
                                <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#w6">
                                    A customer hasn't paid or is unresponsive. What should I do?
                                </button>
                            </h2>
                            <div id="w6" class="accordion-collapse collapse" data-bs-parent="#workerAccordion">
                                <div class="accordion-body">
                                    LabourLink connects you with customers but payment happens directly between you
                                    and them. If there's a dispute, email us at
                                    <a href="mailto:support@labourlink.com">support@labourlink.com</a> with the order
                                    details and we'll look into it.
                                </div>
                            </div>
                        </div>

                    </div>
                </div>
                <% } %>

                <!-- ===================== CONTACT ===================== -->
                <div class="card contact-card shadow-sm">
                    <div class="card-body p-4 text-center">
                        <i class="fas fa-envelope-open-text fa-2x text-success mb-3"></i>
                        <h5>Still need help?</h5>
                        <p class="text-muted mb-3">
                            Our team is happy to help with anything not covered above — account issues, disputes,
                            bugs, or feedback.
                        </p>
                        <a href="mailto:support@labourlink.com" class="btn btn-success">
                            <i class="fas fa-paper-plane me-2"></i>Email support@labourlink.com
                        </a>
                    </div>
                </div>

            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>
