
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Labour-Link AI</title>

<style>

*{
    margin:0;
    padding:0;
    box-sizing:border-box;
}

html,
body{
    width:100%;
    height:100%;
    overflow:hidden;
    font-family:'Segoe UI',sans-serif;
    background:#ffffff;
    color:#111827;
}

.chat-widget{
    width:100%;
    height:100vh;
    display:flex;
    flex-direction:column;
    background:#ffffff;
}

/* Quick Actions */

.quick-actions{
    display:flex;
    flex-wrap:wrap;
    gap:10px;
    padding:12px;
    background:#ffffff;
    border-bottom:1px solid #e5e7eb;
}

.quick-actions button{
    border:none;
    background:#f3f4f6;
    color:#111827;
    padding:10px 14px;
    border-radius:10px;
    cursor:pointer;
    font-size:14px;
    font-weight:500;
    transition:.2s;
}

.quick-actions button:hover{
    background:#e5e7eb;
}

/* Chat Area */

.chat-box{
    flex:1;
    overflow-y:auto;
    padding:15px;
    background:#f9fafb;
}

/* Messages */

.message{
    display:flex;
    margin-bottom:15px;
}

.user{
    justify-content:flex-end;
}

.ai{
    justify-content:flex-start;
}

.bubble{
    max-width:80%;
    padding:12px 15px;
    border-radius:16px;
    line-height:1.6;
    font-size:14px;
    white-space:pre-wrap;
    word-wrap:break-word;
}

.user .bubble{
    background:#2563eb;
    color:#ffffff;
    border-bottom-right-radius:4px;
}

.ai .bubble{
    background:#ffffff;
    color:#111827;
    border:1px solid #e5e7eb;
    border-bottom-left-radius:4px;
    box-shadow:0 2px 8px rgba(0,0,0,0.05);
}

/* Input Area */

.input-area{
    display:flex;
    gap:10px;
    padding:12px;
    background:#ffffff;
    border-top:1px solid #e5e7eb;
}

#message{
    flex:1;
    border:1px solid #d1d5db;
    outline:none;
    background:#ffffff;
    color:#111827;
    padding:12px;
    border-radius:12px;
    font-size:14px;
}

#message:focus{
    border-color:#2563eb;
}

#message::placeholder{
    color:#9ca3af;
}

.send-btn{
    border:none;
    background:#22c55e;
    color:#ffffff;
    padding:12px 18px;
    border-radius:12px;
    cursor:pointer;
    font-weight:600;
    transition:.2s;
}

.send-btn:hover{
    background:#16a34a;
}

/* Typing Animation */

.typing{
    animation:blink 1s infinite;
}

@keyframes blink{
    50%{
        opacity:.5;
    }
}

/* Scrollbar */

.chat-box::-webkit-scrollbar{
    width:6px;
}

.chat-box::-webkit-scrollbar-track{
    background:#f3f4f6;
}

.chat-box::-webkit-scrollbar-thumb{
    background:#d1d5db;
    border-radius:10px;
}

.chat-box::-webkit-scrollbar-thumb:hover{
    background:#9ca3af;
}

</style>
</head>

<body>

<div class="chat-widget">

    <!-- Dynamic Quick Actions -->
    <div class="quick-actions" id="quickActions"></div>

    <!-- Chat Area -->
    <div id="chatBox" class="chat-box"></div>

    <!-- Input Area -->
    <div class="input-area">

        <input
            id="message"
            type="text"
            placeholder="Ask something..."
        >

        <button
            class="send-btn"
            onclick="sendMessage()">
            Send
        </button>

    </div>

</div>

<script>

const chatBox = document.getElementById("chatBox");

/* Load Welcome Message + Quick Actions */

window.addEventListener("DOMContentLoaded", async () => {

    loadWelcomeMessage();
    loadQuickActions();

});

/* Welcome Message */

async function loadWelcomeMessage(){

    try{

        const res = await fetch("/ai/welcome");
        const data = await res.json();

        addAIMessage(
            data.message ||
            "👋 Welcome to Labour-Link AI."
        );

    }catch(err){

        addAIMessage(
            "👋 Welcome to Labour-Link AI. How can I help you today?"
        );

    }

}

/* Quick Actions */

async function loadQuickActions(){

    try{

        const res = await fetch("/ai/actions");
        const data = await res.json();

        const container =
            document.getElementById("quickActions");

        container.innerHTML = "";

        if(data.actions){

            data.actions.forEach(item=>{

                const btn =
                    document.createElement("button");

                btn.innerHTML =
                    `${item.icon || "🤖"} ${item.label}`;

                btn.onclick = () =>
                    quickAsk(item.query);

                container.appendChild(btn);

            });

        }

    }catch(err){

        console.log(
            "Quick actions not loaded"
        );

    }

}

/* Quick Ask */

function quickAsk(text){

    document.getElementById("message").value = text;

    sendMessage();

}

/* Add User Message */

function addUserMessage(text){

    chatBox.innerHTML += `
        <div class="message user">
            <div class="bubble">
                ${escapeHtml(text)}
            </div>
        </div>
    `;

}

/* Add AI Message */

function addAIMessage(text){

    chatBox.innerHTML += `
        <div class="message ai">
            <div class="bubble">
                ${text}
            </div>
        </div>
    `;

    scrollBottom();

}

/* Scroll */

function scrollBottom(){

    chatBox.scrollTop =
        chatBox.scrollHeight;

}

/* Escape HTML */

function escapeHtml(text){

    const div =
        document.createElement("div");

    div.textContent = text;

    return div.innerHTML;

}

/* Send Message */

async function sendMessage(){

    const input =
        document.getElementById("message");

    const text =
        input.value.trim();

    if(!text) return;

    addUserMessage(text);

    input.value = "";

    chatBox.innerHTML += `
        <div
            class="message ai"
            id="typing"
        >
            <div class="bubble typing">
                🤖 Thinking...
            </div>
        </div>
    `;

    scrollBottom();

    try{

        const res =
            await fetch("/ai/ask",{

                method:"POST",

                headers:{
                    "Content-Type":
                    "application/json"
                },

                body:JSON.stringify({
                    message:text
                })

            });

        const data =
            await res.json();

        document
            .getElementById("typing")
            ?.remove();

        addAIMessage(
            data.reply ||
            "No response received."
        );

    }catch(err){

        document
            .getElementById("typing")
            ?.remove();

        addAIMessage(
            "❌ Something went wrong. Please try again."
        );

    }

}

/* Enter Key */

document
.getElementById("message")
.addEventListener(
    "keypress",
    function(e){

        if(e.key === "Enter"){

            sendMessage();

        }

    }
);

</script>

</body>
</html>

