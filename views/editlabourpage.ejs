<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Profile - Labour</title>
    <link rel="stylesheet" href="/css/editlabour.css">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" rel="stylesheet">
</head>
<body>
    <div class="edit-profile-container">
        <!-- Header -->
        <header class="edit-profile-header">
            <div class="header-content">
                <a href="/dashboard" class="back-btn">
                    <i class="fas fa-arrow-left"></i> Back to Dashboard
                </a>
                <h1>Edit Your Profile</h1>
                <div class="header-actions">
                    <a href="/labour/profile" class="view-profile-btn">
                        <i class="fas fa-eye"></i> View Profile
                    </a>
                </div>
            </div>
        </header>

        <!-- Messages -->
        <% if (success) { %>
            <div class="alert alert-success">
                <i class="fas fa-check-circle"></i> <%= success %>
            </div>
        <% } %>
        
        <% if (error) { %>
            <div class="alert alert-error">
                <i class="fas fa-exclamation-circle"></i> <%= error %>
            </div>
        <% } %>

        <div class="edit-profile-content">
            <!-- Left Column - Avatar Upload -->
            <div class="avatar-section">
                <div class="avatar-upload">
                    <div class="avatar-preview">
                        <img id="avatarPreview" src="<%= labour.profileImage || '/images/default-avatar.png' %>" alt="Profile Avatar">
                    </div>
                    <form id="avatarForm" enctype="multipart/form-data">
                        <input type="file" id="avatarInput" name="profileImage" accept="image/*" style="display: none;">
                        <button type="button" class="upload-btn" onclick="document.getElementById('avatarInput').click()">
                            <i class="fas fa-camera"></i> Change Photo
                        </button>
                    </form>
                    <p class="upload-hint">JPG, PNG max 5MB</p>
                </div>

                <div class="profile-stats">
                    <div class="stat-item">
                        <i class="fas fa-star"></i>
                        <div>
                            <span class="stat-value"><%= labour.rating || '4.5' %></span>
                            <span class="stat-label">Rating</span>
                        </div>
                    </div>
                    <div class="stat-item">
                        <i class="fas fa-comment"></i>
                        <div>
                            <span class="stat-value"><%= labour.totalReviews || '0' %></span>
                            <span class="stat-label">Reviews</span>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Right Column - Form -->
            <div class="form-section">
                <form action="/labour/edit-profile" method="POST" enctype="multipart/form-data" class="edit-profile-form" id="profileForm">
                    <!-- Personal Information -->
                    <div class="form-section-card">
                        <h3><i class="fas fa-user"></i> Personal Information</h3>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="name">Full Name *</label>
                                <input type="text" id="name" name="name" value="<%= labour.name %>" required>
                            </div>
                            <div class="form-group">
                                <label for="phone">Phone Number *</label>
                                <input type="tel" id="phone" name="phone" value="<%= labour.phone %>" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="age">Age</label>
                                <input type="number" id="age" name="age" value="<%= labour.age %>" min="18" max="70">
                            </div>
                            <div class="form-group">
                                <label for="profession">Profession *</label>
                                <select id="profession" name="profession" required>
                                    <option value="">Select Profession</option>
                                    <option value="Plumber" <%= labour.profession === 'Plumber' ? 'selected' : '' %>>Plumber</option>
                                    <option value="Electrician" <%= labour.profession === 'Electrician' ? 'selected' : '' %>>Electrician</option>
                                    <option value="Carpenter" <%= labour.profession === 'Carpenter' ? 'selected' : '' %>>Carpenter</option>
                                    <option value="Painter" <%= labour.profession === 'Painter' ? 'selected' : '' %>>Painter</option>
                                    <option value="Cleaner" <%= labour.profession === 'Cleaner' ? 'selected' : '' %>>Cleaner</option>
                                    <option value="AC Repair" <%= labour.profession === 'AC Repair' ? 'selected' : '' %>>AC Repair</option>
                                    <option value="Mason" <%= labour.profession === 'Mason' ? 'selected' : '' %>>Mason</option>
                                    <option value="Welder" <%= labour.profession === 'Welder' ? 'selected' : '' %>>Welder</option>
                                    <option value="Mechanic" <%= labour.profession === 'Mechanic' ? 'selected' : '' %>>Mechanic</option>
                                    <option value="Technician" <%= labour.profession === 'Technician' ? 'selected' : '' %>>Technician</option>
                                </select>
                            </div>
                        </div>
                    </div>

                    <!-- Professional Details -->
                    <div class="form-section-card">
                        <h3><i class="fas fa-briefcase"></i> Professional Details</h3>
                        
                        <div class="form-row">
                            <div class="form-group">
                                <label for="experience">Experience *</label>
                                <input type="text" id="experience" name="experience" 
                                       value="<%= labour.experience %>" 
                                       placeholder="e.g., 5 years" required>
                            </div>
                            <div class="form-group">
                                <label for="wagePerHour">Wage per Hour (₹) *</label>
                                <input type="number" id="wagePerHour" name="wagePerHour" 
                                       value="<%= labour.wagePerHour %>" min="0" step="1" required>
                            </div>
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="wagePerDay">Wage per Day (₹) *</label>
                                <input type="number" id="wagePerDay" name="wagePerDay" 
                                       value="<%= labour.wagePerDay %>" min="0" step="1" required>
                            </div>
                        </div>
                    </div>

                    <!-- Address Information -->
                    <div class="form-section-card">
                        <h3><i class="fas fa-map-marker-alt"></i> Address Information</h3>
                        
                        <div class="form-group">
                            <label for="street">Street Address</label>
                            <input type="text" id="street" name="street" 
                                   value="<%= labour.address.street %>">
                        </div>

                        <div class="form-row">
                            <div class="form-group">
                                <label for="city">City *</label>
                                <input type="text" id="city" name="city" 
                                       value="<%= labour.address.city %>" required>
                            </div>
                            <div class="form-group">
                                <label for="state">State *</label>
                                <input type="text" id="state" name="state" 
                                       value="<%= labour.address.state %>" required>
                            </div>
                        </div>

                        <div class="form-group">
                            <label for="zipCode">ZIP Code</label>
                            <input type="text" id="zipCode" name="zipCode" 
                                   value="<%= labour.address.zipCode %>">
                        </div>
                    </div>

                    <!-- Form Actions -->
                    <div class="form-actions">
                        <button type="button" class="cancel-btn" onclick="window.history.back()">
                            Cancel
                        </button>
                        <button type="submit" class="save-btn">
                            <i class="fas fa-save"></i> Save Changes
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script>
        // Avatar preview functionality
        document.getElementById('avatarInput').addEventListener('change', function(e) {
            const file = e.target.files[0];
            if (file) {
                const reader = new FileReader();
                reader.onload = function(e) {
                    document.getElementById('avatarPreview').src = e.target.result;
                    // Auto-submit form when new image is selected
                    document.getElementById('profileForm').submit();
                }
                reader.readAsDataURL(file);
            }
        });

        // Auto-calculate daily wage based on hourly rate
        document.getElementById('wagePerHour').addEventListener('input', function() {
            const hourlyRate = parseFloat(this.value) || 0;
            const dailyRate = hourlyRate * 8; // 8 hours per day
            document.getElementById('wagePerDay').value = Math.round(dailyRate);
        });

        // Form validation
        document.getElementById('profileForm').addEventListener('submit', function(e) {
            const hourlyRate = parseFloat(document.getElementById('wagePerHour').value);
            const dailyRate = parseFloat(document.getElementById('wagePerDay').value);
            
            if (hourlyRate <= 0 || dailyRate <= 0) {
                e.preventDefault();
                alert('Please enter valid wage rates.');
                return false;
            }
        });
    </script>
</body>
</html>